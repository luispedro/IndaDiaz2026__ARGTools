rule fargene:
    input:
        comp_file1 = expand(data_dir+"{{runs}}", runs=runs)
    output:
        out1_fargene = expand(work_dir+"/fargene_results/{{runs}}-{{class_ab}}.tsv", runs=runs, class_ab=class_ab),
        out2_fargene = expand(work_dir+"/fargene_predicted/{{runs}}-{{class_ab}}.fasta", runs=runs, class_ab=class_ab),
        out3_fargene = expand(work_dir+"/fargene_hmm/{{runs}}-{{class_ab}}_hmm.txt", runs=runs, class_ab=class_ab)
    params:
        num_of_processes = 1,
        model = lambda wildcards: model_class[wildcards.class_ab],
        data_dir = data_dir
    threads: 1
    shadow: "minimal"
    conda:
        "fargene"
    shell:
        """
        echo $CONDA_PREFIX
        echo "fargene  {wildcards.runs} class {params.model}"
        if [ {params.model} == "none" ]; then
          echo "no class given"
        else
          if [ -s {params.data_dir}{wildcards.runs} ]; then
            gunzip < {params.data_dir}{wildcards.runs} > tmp.fasta
            echo "running fargene"
            fargene -i tmp.fasta --protein --hmm-model {params.model} -o tmp_fargene -p {params.num_of_processes} --force
          else
            echo "creating directories"
            mkdir tmp_fargene
            mkdir tmp_fargene/tmpdir
            mkdir tmp_fargene/predictedGenes
            mkdir tmp_fargene/hmmsearchresults
            touch tmp_fargene/tmpdir/tmp-positives.out
            touch tmp_fargene/predictedGenes/filtered.fasta
            touch tmp_fargene/hmmsearchresults/a_hmmsearched.out
          fi
          if [ -s tmp_fargene/tmpdir/tmp-positives.out ]; then
            echo "copying positives"
            mod={wildcards.class_ab}
            awk -v ab="$mod" -F' ' '{{print $0, ab}}' tmp_fargene/tmpdir/tmp-positives.out | awk '{{gsub(/ +/, "\t"); print}}' > {output.out1_fargene}
            echo "copying contigs"
            cp tmp_fargene/predictedGenes/*filtered.fasta {output.out2_fargene}
            echo "copying hmm"
            grep -v '^#' tmp_fargene/hmmsearchresults/*hmmsearched.out > {output.out3_fargene}
          else
            echo "creating files"
            touch {output.out1_fargene}
            touch {output.out2_fargene}
            grep -v '^#' tmp_fargene/hmmsearchresults/*hmmsearched.out > {output.out3_fargene}
          fi
        fi
        """

rule rgi:
    input:
        comp_file1 = expand(data_dir+"{{runs}}", runs=runs)
    output:
        out_rgi_diamond = work_dir+"/rgi_diamond/{runs}_rgi.tsv"
    params:
        num_of_processes = 4,
        work_dire = work_dir
    threads: 4
    shadow: "minimal"
    shell:
        """
        echo "RGI  {wildcards.runs} "
        if [ -s {input.comp_file1} ]; then
          gunzip <{input.comp_file1} > tmp.faa
          mamba run -n rgi rgi load --card_json /work/microbiome/users/juan/rgi/card.json --local
          mamba run -n rgi rgi main -a DIAMOND -i tmp.faa -o tmpout --local --clean -t protein --num_threads {params.num_of_processes}
          cat tmpout.txt > {output.out_rgi_diamond}
        else
          touch {output.out_rgi_diamond}
        fi
        """

