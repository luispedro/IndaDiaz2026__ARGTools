rule deepARG:
    input:
        comp_file1 = expand(data_dir+"{{runs}}", runs=runs)
    output:
        out_deeparg_prot = work_dir+"/deeparg/{runs}.ARG",
        out_deeparg_prot_potential = work_dir+"/deeparg/{runs}.potential.ARG"
    params:
        num_of_processes = 4,
        work_dire = work_dir,
        path_data_deeparg = "/work/microbiome/users/juan/deeparg_data"
    threads: 4
    shadow: "minimal"
    conda:
        "deeparg_env"
    shell:
        """
        echo "deepARG  {wildcards.runs} "
        if [ -s {input.comp_file1} ]; then
          gunzip <{input.comp_file1} > tmp.fasta
          deeparg predict --model LS -i tmp.fasta -o tmpout -d {params.path_data_deeparg} --type prot
          mv tmpout.mapping.ARG {output.out_deeparg_prot}
          mv tmpout.mapping.potential.ARG {output.out_deeparg_prot_potential}
        else
          touch {output.out_deeparg_prot}
          touch {output.out_deeparg_prot_potential}
        fi
        """

